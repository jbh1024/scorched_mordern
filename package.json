{
  "name": "scorched-modern",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/client"
  ],
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "npm run dev -w @scorched/client",
    "dev:server": "npm run dev -w @scorched/server",
    "build": "npm run build -w @scorched/shared && npm run build -w @scorched/server && npm run build -w @scorched/client",
    "lint": "eslint packages/*/src --ext .ts,.tsx",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.1"
  }
}
